{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.js"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/roi",
            "schedule": "30 18 * * *"
        },
        {
            "path": "/api/cron/auto-upgrade",
            "schedule": "30 19 * * *"
        }
    ]
}